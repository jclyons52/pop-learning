{
  "//": "Deno-only toolchain: format, type-check and test. No npm, no registry installs. Node built-ins come from Deno's own bundled compatibility layer.",
  "tasks": {
    "fmt": "deno fmt",
    "fmt:check": "deno fmt --check",
    "check": "deno check shared/plan-core.js",
    "test": "deno test --no-check tests/plan-core.test.js",
    "syntax": "deno run --allow-read tests/syntax-check.js",
    "validate": "deno run --allow-read tests/validate.js",
    "stamp": "deno run --allow-read --allow-write tests/stamp-sw.js",
    "split": "deno run --allow-read --allow-write tests/split-audio.js",
    "all": "deno task fmt:check && deno task syntax && deno task validate && deno task test && deno task check"
  },
  "fmt": {
    "exclude": ["icons", "**/*.html"],
    "lineWidth": 110,
    "proseWrap": "preserve"
  },
  "compilerOptions": {
    "checkJs": true,
    "lib": ["deno.ns", "dom", "es2020"]
  }
}
